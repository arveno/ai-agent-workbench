# CloudBase Auth / HTTP Functions are the default frontend path.
# 本地 Vite proxy 场景留空，EdgeOne 线上填写 CloudBase 默认域名。
VITE_API_BASE_URL=
VITE_CLOUDBASE_ENV_ID=
VITE_CLOUDBASE_REGION=ap-shanghai

# CloudBase 控制台需开启“用户名密码登录”。
# 该能力不需要额外 VITE_ 密钥；用户名和密码由用户在登录弹窗输入。

# 本地 Vite dev proxy 目标，不是前端公开变量，不会暴露给浏览器。
# 本地 CloudBase 开发时建议设置它，并保持 VITE_API_BASE_URL 为空。
CLOUDBASE_PROXY_TARGET=

# Model Gateway 服务端 Key，只能配置在 CloudBase 函数环境变量中。
# 前端不要配置模型 Key，也不要添加 VITE_ 前缀。
SILICONFLOW_API_KEY=
ZHIPU_API_KEY=

# 可选：覆盖 modelGateway.js 中的默认国内 OpenAI-compatible endpoint / model。
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
SILICONFLOW_MODEL_QWEN=Qwen/Qwen2.5-7B-Instruct
SILICONFLOW_MODEL_GLM=THUDM/GLM-4-9B-0414
ZHIPU_MODEL_GLM_FLASH=glm-4-flash-250414
MODEL_GATEWAY_TIMEOUT_MS=30000
