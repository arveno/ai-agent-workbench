# CloudBase Auth / HTTP Functions are the default frontend path.
# 本地 Vite proxy 场景留空，EdgeOne 线上填写 CloudBase 默认域名。
VITE_API_BASE_URL=
VITE_CLOUDBASE_ENV_ID=
VITE_CLOUDBASE_REGION=ap-shanghai

# CloudBase 控制台需开启“用户名密码登录”。
# 该能力不需要额外 VITE_ 密钥；用户名和密码由用户在登录弹窗输入。

# 本地 Vite dev proxy 目标，不是前端公开变量，不会暴露给浏览器。
# 本地 CloudBase 开发时建议设置它，并保持 VITE_API_BASE_URL 为空。
CLOUDBASE_PROXY_TARGET=

# Optional legacy rollback flag.
# 默认不配置或留空时使用 CloudBase Auth / CloudBase private APIs。
# 只有需要临时回滚旧 Vercel/Supabase 链路时才设置为 false。
VITE_ENABLE_CLOUDBASE_PRIVATE_API=

# Legacy Supabase rollback config.
# 保留给迁移期回滚，不再是默认正式身份来源。
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional server-side Supabase project URL.
# If omitted, server auth helpers can reuse VITE_SUPABASE_URL.
SUPABASE_URL=

# Groq 服务端 Key，只能配置在服务端环境变量中
GROQ_API_KEY=

# Supabase / PostgreSQL 服务端数据库连接串，只能配置在服务端环境变量中
SUPABASE_DB_CONNECTION_STRING=
POSTGRES_CONNECTION_STRING=

# Supabase service_role / secret key 只能用于受信任的服务端接口
# 不能填写到任何 VITE_ 变量，也不能暴露给浏览器
SUPABASE_SERVICE_ROLE_KEY=
