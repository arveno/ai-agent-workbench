# CloudBase Auth / HTTP Functions are the default frontend path.
# 本地 Vite proxy 场景留空，EdgeOne 线上填写 CloudBase 默认域名。
VITE_API_BASE_URL=
VITE_CLOUDBASE_ENV_ID=
VITE_CLOUDBASE_REGION=ap-shanghai

# CloudBase 控制台需开启“用户名密码登录”。
# 该能力不需要额外 VITE_ 密钥；用户名和密码由用户在登录弹窗输入。

# 本地 Vite dev proxy 目标，不是前端公开变量，不会暴露给浏览器。
# 本地 CloudBase 开发时建议设置它，并保持 VITE_API_BASE_URL 为空。
CLOUDBASE_PROXY_TARGET=

# Groq 服务端 Key，只能配置在服务端环境变量中
GROQ_API_KEY=

# Legacy / archive only.
# Vercel / Supabase 旧代码仍暂存在仓库中供历史对照，当前 CloudBase 单轨启动不需要以下变量。
# VITE_SUPABASE_URL=
# VITE_SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_URL=
# SUPABASE_DB_CONNECTION_STRING=
# POSTGRES_CONNECTION_STRING=
# SUPABASE_SERVICE_ROLE_KEY=
