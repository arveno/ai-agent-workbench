# Supabase 项目地址，用于前端连接你的 Supabase 项目
VITE_SUPABASE_URL=

# Supabase 前端公开 Key，用于浏览器端初始化 Supabase Auth 登录
# 这个 key 可以放前端，但只能使用低权限的 publishable / anon key
# 不能填写 service_role / secret key
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional server-side Supabase project URL.
# If omitted, server auth helpers can reuse VITE_SUPABASE_URL.
SUPABASE_URL=

# Groq 服务端 Key，只能配置在服务端环境变量中
GROQ_API_KEY=

# Supabase / PostgreSQL 服务端数据库连接串，只能配置在服务端环境变量中
SUPABASE_DB_CONNECTION_STRING=
POSTGRES_CONNECTION_STRING=

# Supabase service_role / secret key 只能用于受信任的服务端接口
# 不能填写到任何 VITE_ 变量，也不能暴露给浏览器
SUPABASE_SERVICE_ROLE_KEY=
